---
import Base from '../layouts/Base.astro';
import MetricCard from '../components/MetricCard.astro';
import ModelBadge from '../components/ModelBadge.astro';
import DotPlot from '../components/DotPlot.astro';
import Callout from '../components/Callout.astro';
import { SITE, LINKS, ASSETS, KEY_FACTS, HEADLINE, LOWDATA, withBase } from '../lib/site';

const flow = [
  'GMD performances',
  'two-bar clips',
  '16 kHz / 32 kHz mono',
  'primary ⊕ secondary labels',
  '74 style classes',
  'CNN vs PaSST',
  'macro-F1',
];
---

<Base path="/">
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="container hero__inner">
      <p class="eyebrow hero__kicker">
        <span class="pill">Published at ISMIR 2025</span>
        MSc Thesis · Leiden University
      </p>
      <h1 class="hero__title">{SITE.hero}</h1>
      <p class="lede hero__lede">{SITE.tagline}</p>

      <div class="hero__cta">
        <a class="btn btn--primary" href={withBase('/experiments')}>Explore the results</a>
        <a class="btn" href={withBase(ASSETS.thesisPdf)}>Read the thesis</a>
        <a class="btn" href={withBase(ASSETS.lbdPdf)}>ISMIR paper</a>
        <a class="btn" href={LINKS.video} rel="noopener">Watch the talk</a>
        <a class="btn" href={LINKS.repo} rel="noopener">View code</a>
      </div>
    </div>
  </section>

  <!-- ===================== METRICS ===================== -->
  <section class="band-sunken">
    <div class="container">
      <div class="metrics">
        {KEY_FACTS.map((f) => <MetricCard value={f.value} label={f.label} note={f.note} />)}
      </div>
    </div>
  </section>

  <!-- ===================== THE RESULT, IN ONE BREATH ===================== -->
  <section>
    <div class="container">
      <div class="prose measure-wide">
        <p class="eyebrow">The finding</p>
        <p class="big-claim">
          A drum-specific <ModelBadge model="cnn" size="md" /> trained from scratch reached the
          strongest aggregate score on the full 74-class task, yet frozen
          <ModelBadge model="passt" size="md" /> transfer learning won under data scarcity and
          organized drum style into a more stable, hierarchical representation.
        </p>
        <p class="big-claim__sub muted">
          Transfer learning helped, but its value depended on data availability, classifier
          design, and how well general AudioSet pretraining aligned with fine-grained drum-style
          distinctions. The story is not “one model beat the other.”
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== WHY DRUM STYLE ===================== -->
  <section class="band-sunken">
    <div class="container">
      <p class="eyebrow">Why drum style?</p>
      <h2 class="section-h">Not a single hit. Not a transcription. A whole groove.</h2>
      <div class="three-up">
        <div class="card">
          <h3>Single-hit classification</h3>
          <p class="muted">Is this one sound a snare, a kick, a cymbal? Timbre of an isolated onset.</p>
        </div>
        <div class="card">
          <h3>Drum transcription</h3>
          <p class="muted">Notate every onset into MIDI: a symbolic event sequence, no style label.</p>
        </div>
        <div class="card card--accent">
          <h3>Drum-pattern <em>style</em></h3>
          <p class="muted">
            Read an entire two-bar performance and name its style: the higher-level, genre-like
            task this thesis investigates directly from audio.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== DATASET PIPELINE ===================== -->
  <section>
    <div class="container">
      <p class="eyebrow">The data</p>
      <h2 class="section-h">From professional grooves to a 74-class audio task</h2>
      <p class="lede measure">
        To avoid building a dataset from scratch, the project adopted the
        <strong>Groove MIDI Dataset</strong> (professional drummer performances with primary and
        secondary style annotations) and rendered <strong>18,264</strong> two-bar audio clips.
      </p>
      <ol class="flow" aria-label="Data processing pipeline">
        {flow.map((step, i) => (
          <li class="flow__step">
            <span class="flow__num">{i + 1}</span>
            <span>{step}</span>
          </li>
        ))}
      </ol>
      <p class="muted measure" style="margin-top: var(--sp-4)">
        Clips are mono, padded to a fixed length, split ≈80 / 10 / 10 with proportional class
        balancing. Concatenating primary and secondary annotations yields the 74 classes, an
        intentionally fine-grained, imbalanced target (rock styles alone make up nearly two-thirds
        of the data).
      </p>
    </div>
  </section>

  <!-- ===================== MODEL COMPARISON ===================== -->
  <section class="band-sunken">
    <div class="container">
      <p class="eyebrow">Two ways to hear a groove</p>
      <h2 class="section-h">A task-specific CNN versus a pretrained transformer</h2>
      <div class="versus">
        <article class="vs-card vs-card--cnn">
          <header><ModelBadge model="cnn" size="md" /> <span class="vs-card__tag">learned from scratch</span></header>
          <ul>
            <li>Log-mel spectrogram input at 16 kHz</li>
            <li>Stacked local convolutional filters</li>
            <li>VGG-style, adapted for drums</li>
            <li>Best configuration: <strong>7 convolutional layers</strong></li>
            <li>Captures local spectro-temporal, drum-specific cues</li>
          </ul>
        </article>
        <div class="versus__div" aria-hidden="true">vs</div>
        <article class="vs-card vs-card--passt">
          <header><ModelBadge model="passt" size="md" /> <span class="vs-card__tag">transfer learning</span></header>
          <ul>
            <li>Audio resampled to 32 kHz, padded to 10 s</li>
            <li>Patchout Audio Spectrogram Transformer</li>
            <li><strong>Frozen</strong> AudioSet-pretrained backbone</li>
            <li>Best head: <strong>4-layer MLP</strong> classifier</li>
            <li>Brings broad general-audio knowledge to the task</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================== THE TWO HEADLINE CHARTS ===================== -->
  <section>
    <div class="container">
      <p class="eyebrow">The evidence</p>
      <h2 class="section-h">Two charts carry the argument</h2>
      <div class="charts-2">
        <DotPlot
          title="On the full 74-class task, the CNN edges ahead"
          metric="macro-F1"
          items={[
            { label: 'CNN', value: HEADLINE.cnn.f1, model: 'cnn', sub: `exp ${HEADLINE.cnn.exp}` },
            { label: 'PaSST', value: HEADLINE.passt.f1, model: 'passt', sub: `exp ${HEADLINE.passt.exp}` },
          ]}
          caption="Best configuration per model, GMD-full, 74 classes, a directly comparable pair."
          source="Thesis Experiment results.xlsx · Overall"
        />
        <DotPlot
          title="But under data scarcity, the ranking reverses"
          metric="macro-F1"
          items={[
            { label: 'PaSST', value: LOWDATA.passt, model: 'passt', sub: 'exp 3.2' },
            { label: 'CNN', value: LOWDATA.cnn, model: 'cnn', sub: 'exp 3.1' },
          ]}
          caption={`${LOWDATA.scope}: frozen transfer features give PaSST the advantage when data is limited.`}
          source="Thesis Experiment results.xlsx · Dataset Exploration"
        />
      </div>
      <p class="muted measure" style="margin-top: var(--sp-5)">
        The early rock-only experiment scored a higher 0.9204, but on a narrower, easier label set, so it
        it belongs to the <a href={withBase('/experiments')}>experiment history</a>, not the headline.
      </p>
    </div>
  </section>

  <!-- ===================== EMBEDDINGS TEASER ===================== -->
  <section class="band-sunken">
    <div class="container">
      <p class="eyebrow">What the models learned</p>
      <h2 class="section-h">Accuracy isn’t the whole story: the representations differ</h2>
      <div class="split">
        <div class="prose">
          <p>
            Beyond F1, the two models organize drum style differently. PaSST shows tighter clustering
            by primary style and smaller mean centroid shifts under perturbation, evidence of a more
            hierarchical embedding. The CNN leans on local features and is more sensitive to class
            imbalance.
          </p>
          <p>
            <a href={withBase('/representations')}>See the representation analysis →</a>
          </p>
        </div>
        <Callout variant="warn" title="Methods note">
          <p>
            The CNN and PaSST embeddings live in <strong>different coordinate systems</strong>. Raw
            centroid-shift magnitudes are not comparable across models (PaSST 8.32 vs CNN 94.66 under
            reflection padding). Comparisons here use within-model ranks and normalized shifts only.
          </p>
        </Callout>
      </div>
    </div>
  </section>

  <!-- ===================== LIMITATIONS ===================== -->
  <section>
    <div class="container">
      <p class="eyebrow">Read with care</p>
      <h2 class="section-h">Limitations</h2>
      <ul class="limits">
        <li>Labels derive from dataset style tags, with ambiguous, overlapping genre boundaries.</li>
        <li>The 74-class target is imbalanced; rock dominates.</li>
        <li>Two-bar clips omit longer musical structure.</li>
        <li>PaSST was used <strong>frozen</strong>, not fine-tuned, which limits task adaptation.</li>
        <li>Results are specific to GMD and its rendering conditions.</li>
        <li>t-SNE is exploratory, not proof of semantic separation.</li>
      </ul>
    </div>
  </section>

  <!-- ===================== PUBLICATION ===================== -->
  <section class="band-invert">
    <div class="container pub">
      <div>
        <p class="eyebrow" style="color: var(--accent-glow)">ISMIR 2025 · Late-Breaking Demo</p>
        <h2 class="section-h" style="color: var(--ink-on-invert)">Read, cite, and watch the work</h2>
        <p class="lede" style="color: var(--ink-on-invert); opacity: 0.85">
          Daejeon, South Korea. The full thesis, the Late-Breaking Demo paper, the poster, and the
          recorded presentation are all one click away.
        </p>
      </div>
      <div class="pub__links">
        <a class="btn btn--ghost" href={withBase(ASSETS.thesisPdf)}>Thesis (PDF)</a>
        <a class="btn btn--ghost" href={withBase(ASSETS.lbdPdf)}>LBD paper (PDF)</a>
        <a class="btn btn--ghost" href={withBase(ASSETS.posterPdf)}>Poster</a>
        <a class="btn btn--ghost" href={LINKS.video} rel="noopener">Video</a>
        <a class="btn btn--ghost" href={withBase('/publication')}>Publication details →</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- Hero ---------- */
  .hero { padding-block: clamp(var(--sp-7), 9vw, var(--sp-9)); position: relative; }
  .hero::after {
    content: '';
    position: absolute; inset: 0; z-index: -1;
    background:
      radial-gradient(120% 80% at 85% -10%, var(--accent-tint) 0%, transparent 55%),
      radial-gradient(80% 60% at 0% 0%, color-mix(in srgb, var(--cnn-tint) 60%, transparent) 0%, transparent 50%);
    opacity: 0.7;
  }
  .hero__inner { max-width: 56rem; }
  .hero__kicker { display: flex; align-items: center; gap: 0.7rem; flex-wrap: wrap; margin-bottom: var(--sp-5); color: var(--ink-3); }
  .pill {
    background: var(--btn-bg); color: #fff;
    padding: 0.18em 0.7em; border-radius: 999px;
    font-size: var(--step--2); letter-spacing: 0.06em; text-transform: none;
  }
  .hero__title { font-size: var(--step-5); max-width: 18ch; }
  .hero__lede { margin-top: var(--sp-4); max-width: 50ch; font-size: var(--step-2); }
  .hero__cta { display: flex; flex-wrap: wrap; gap: var(--sp-3); margin-top: var(--sp-6); }

  /* ---------- Buttons ---------- */
  .btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.6rem 1.1rem;
    border: 1px solid var(--rule-strong);
    border-radius: 999px;
    background: var(--bg-raised);
    color: var(--ink);
    text-decoration: none;
    font-size: var(--step--1); font-weight: 540;
    transition: transform 0.12s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .btn:hover { transform: translateY(-1px); border-color: var(--accent); }
  .btn--primary { background: var(--btn-bg); color: #fff; border-color: var(--btn-bg); }
  .btn--primary:hover { background: var(--accent-strong); border-color: var(--accent-strong); }
  .btn--ghost { background: transparent; color: var(--ink-on-invert); border-color: color-mix(in srgb, var(--ink-on-invert) 35%, transparent); }
  .btn--ghost:hover { background: color-mix(in srgb, var(--ink-on-invert) 12%, transparent); border-color: var(--accent-glow); }

  /* ---------- Bands ---------- */
  .band-sunken { background: var(--bg-sunken); }
  .band-invert { background: var(--bg-invert); }

  /* ---------- Metrics ---------- */
  .metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--sp-5); }
  @media (max-width: 720px) { .metrics { grid-template-columns: repeat(2, 1fr); gap: var(--sp-4); } }

  /* ---------- Section heads ---------- */
  .section-h { margin-top: var(--sp-2); margin-bottom: var(--sp-5); max-width: 24ch; }
  .measure-wide { max-width: 60ch; }
  .measure { max-width: var(--measure); }

  .big-claim { font-family: var(--font-display); font-size: var(--step-2); line-height: 1.34; font-weight: 420; }
  .big-claim__sub { font-size: var(--step-0); margin-top: var(--sp-4); max-width: 58ch; }

  /* ---------- Three-up cards ---------- */
  .three-up { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-4); margin-top: var(--sp-5); }
  @media (max-width: 820px) { .three-up { grid-template-columns: 1fr; } }
  .card { background: var(--bg-raised); border: 1px solid var(--rule); border-radius: var(--radius-lg); padding: var(--sp-5); }
  .card h3 { font-size: var(--step-1); margin-bottom: var(--sp-2); }
  .card--accent { border-color: var(--accent); border-top: 3px solid var(--accent); }

  /* ---------- Flow ---------- */
  .flow { list-style: none; padding: 0; margin-top: var(--sp-5); display: flex; flex-wrap: wrap; gap: var(--sp-2); align-items: stretch; }
  .flow__step {
    display: flex; align-items: center; gap: 0.5rem;
    background: var(--bg-raised); border: 1px solid var(--rule);
    border-radius: 999px; padding: 0.45rem 0.9rem 0.45rem 0.45rem;
    font-size: var(--step--1); position: relative;
  }
  .flow__step:not(:last-child)::after { content: '→'; margin-left: 0.4rem; color: var(--accent); font-weight: 700; }
  .flow__num {
    display: grid; place-items: center;
    width: 1.5rem; height: 1.5rem; border-radius: 50%;
    background: var(--accent-tint); color: var(--accent-strong);
    font-family: var(--font-mono); font-size: var(--step--2); font-weight: 600; flex: none;
  }

  /* ---------- Versus ---------- */
  .versus { display: grid; grid-template-columns: 1fr auto 1fr; gap: var(--sp-4); align-items: stretch; margin-top: var(--sp-5); }
  @media (max-width: 760px) { .versus { grid-template-columns: 1fr; } .versus__div { display: none; } }
  .vs-card { background: var(--bg-raised); border: 1px solid var(--rule); border-radius: var(--radius-lg); padding: var(--sp-5); }
  .vs-card--cnn { border-top: 3px solid var(--cnn); }
  .vs-card--passt { border-top: 3px solid var(--passt); }
  .vs-card header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: var(--sp-4); flex-wrap: wrap; }
  .vs-card__tag { font-family: var(--font-mono); font-size: var(--step--2); color: var(--ink-3); }
  .vs-card ul { list-style: none; padding: 0; display: grid; gap: 0.6rem; }
  .vs-card li { padding-left: 1.2rem; position: relative; font-size: var(--step--1); color: var(--ink-2); }
  .vs-card li::before { content: ''; position: absolute; left: 0; top: 0.55em; width: 0.45rem; height: 0.45rem; border-radius: 50%; background: var(--rule-strong); }
  .vs-card--cnn li::before { background: var(--cnn); }
  .vs-card--passt li::before { background: var(--passt); }
  .versus__div { align-self: center; font-family: var(--font-display); font-style: italic; color: var(--ink-3); font-size: var(--step-2); }

  /* ---------- Charts ---------- */
  .charts-2 { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-5); margin-top: var(--sp-5); }
  @media (max-width: 860px) { .charts-2 { grid-template-columns: 1fr; } }

  /* ---------- Split ---------- */
  .split { display: grid; grid-template-columns: 1.2fr 1fr; gap: var(--sp-6); align-items: start; margin-top: var(--sp-5); }
  @media (max-width: 820px) { .split { grid-template-columns: 1fr; } }

  /* ---------- Limits ---------- */
  .limits { columns: 2; column-gap: var(--sp-7); max-width: 70ch; margin-top: var(--sp-4); padding-left: 1.1em; }
  .limits li { margin-bottom: var(--sp-3); break-inside: avoid; }
  @media (max-width: 640px) { .limits { columns: 1; } }

  /* ---------- Publication ---------- */
  .pub { display: grid; grid-template-columns: 1.4fr 1fr; gap: var(--sp-6); align-items: center; }
  @media (max-width: 820px) { .pub { grid-template-columns: 1fr; } }
  .pub__links { display: flex; flex-wrap: wrap; gap: var(--sp-3); }
</style>
