---
import { NAV, SITE, withBase } from '../lib/site';
interface Props { path?: string }
const { path = '/' } = Astro.props;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-head">
  <div class="container site-head__inner">
    <a class="brand" href={withBase('/')} aria-label={`${SITE.shortTitle} home`}>
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__text">Probing the World<br />for Groove</span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {NAV.map((item) => (
          <li>
            <a
              href={withBase(item.href)}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-head {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(1.4) blur(8px);
    border-bottom: 1px solid var(--rule);
  }
  .site-head__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    min-height: 4rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--ink);
    font-family: var(--font-display);
    line-height: 1.04;
    font-size: 0.95rem;
    font-weight: 520;
    letter-spacing: -0.01em;
  }
  .brand__mark {
    width: 1.45rem; height: 1.45rem;
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 50%, transparent 22%, var(--accent) 23% 30%, transparent 31%),
      radial-gradient(circle at 50% 50%, transparent 44%, var(--accent) 45% 52%, transparent 53%),
      radial-gradient(circle at 50% 50%, var(--accent-strong) 0 9%, transparent 10%);
    flex: none;
  }
  .site-nav ul {
    list-style: none;
    display: flex;
    gap: clamp(0.6rem, 1.6vw, 1.5rem);
    padding: 0; margin: 0;
    align-items: center;
  }
  .site-nav a {
    color: var(--ink-2);
    text-decoration: none;
    font-size: var(--step--1);
    font-weight: 500;
    padding: 0.4rem 0.1rem;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }
  .site-nav a:hover { color: var(--ink); }
  .site-nav a[aria-current='page'] {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  /* Mobile menu */
  .nav-toggle, .nav-burger { display: none; }
  @media (max-width: 720px) {
    .nav-burger {
      display: inline-flex;
      flex-direction: column;
      justify-content: center;
      gap: 4px;
      width: 2.5rem; height: 2.5rem;
      cursor: pointer;
      border: 1px solid var(--rule-strong);
      border-radius: var(--radius);
      padding: 0.5rem;
    }
    .nav-burger span {
      height: 2px; width: 100%;
      background: var(--ink);
      border-radius: 2px;
    }
    .site-nav {
      position: absolute;
      top: 100%; left: 0; right: 0;
      background: var(--bg-raised);
      border-bottom: 1px solid var(--rule);
      box-shadow: var(--shadow-2);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease;
    }
    .site-nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: var(--sp-2) 0;
    }
    .site-nav li { padding-inline: clamp(1.1rem, 4vw, 3rem); }
    .site-nav a {
      display: block;
      padding: 0.7rem 0;
      font-size: var(--step-0);
      border-bottom: none;
    }
    .nav-toggle:checked ~ .site-nav { max-height: 22rem; }
  }
</style>
