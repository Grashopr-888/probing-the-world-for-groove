---
interface Props { value: string; label: string; note?: string }
const { value, label, note } = Astro.props;
---
<div class="metric">
  <span class="metric__value">{value}</span>
  <span class="metric__label">{label}</span>
  {note && <span class="metric__note">{note}</span>}
</div>

<style>
  .metric {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: var(--sp-4) 0;
    border-top: 2px solid var(--accent);
  }
  .metric__value {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 480;
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .metric__label { font-size: var(--step-0); color: var(--ink-2); font-weight: 500; }
  .metric__note { font-size: var(--step--1); color: var(--ink-3); }
</style>
