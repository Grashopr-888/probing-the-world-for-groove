---
interface Props { variant?: 'note' | 'warn' | 'accent'; title?: string }
const { variant = 'note', title } = Astro.props;
---
<aside class={`callout callout--${variant}`}>
  {title && <p class="callout__title">{title}</p>}
  <div class="callout__body"><slot /></div>
</aside>

<style>
  .callout {
    border-left: 3px solid var(--rule-strong);
    background: var(--bg-raised);
    padding: var(--sp-4) var(--sp-5);
    border-radius: 0 var(--radius) var(--radius) 0;
    box-shadow: var(--shadow-1);
  }
  .callout--accent { border-left-color: var(--accent); }
  .callout--warn { border-left-color: var(--warn); background: var(--warn-tint); }
  .callout__title {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin-bottom: var(--sp-2);
  }
  .callout--warn .callout__title { color: var(--warn); }
  .callout__body { font-size: var(--step--1); color: var(--ink-2); }
  .callout__body :global(p + p) { margin-top: var(--sp-3); }
</style>
