---
interface Props { eyebrow: string; title: string; lede?: string }
const { eyebrow, title, lede } = Astro.props;
---
<header class="page-head">
  <div class="container">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="page-head__title">{title}</h1>
    {lede && <p class="lede page-head__lede">{lede}</p>}
  </div>
</header>

<style>
  .page-head {
    padding-block: clamp(var(--sp-6), 7vw, var(--sp-8)) var(--sp-5);
    border-bottom: 1px solid var(--rule);
    background:
      radial-gradient(90% 120% at 100% -20%, var(--accent-tint) 0%, transparent 50%);
  }
  .page-head__title { font-size: var(--step-4); margin-top: var(--sp-3); max-width: 20ch; }
  .page-head__lede { margin-top: var(--sp-4); max-width: 58ch; }
</style>
